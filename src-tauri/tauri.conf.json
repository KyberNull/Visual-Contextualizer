{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "visual-contextualizer",
  "version": "0.1.0",
  "identifier": "io.github.KyberNull.visual-contextualizer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Visual Contextualizer",
        "width": 400,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "deb": {
        "files": {
          "/usr/lib/visual-contextualizer/libllama.so.0": "target/llama-libs/libllama.so.0",
          "/usr/lib/visual-contextualizer/libmtmd.so.0": "target/llama-libs/libmtmd.so.0",
          "/usr/lib/visual-contextualizer/libggml.so.0": "target/llama-libs/libggml.so.0",
          "/usr/lib/visual-contextualizer/libggml-base.so.0": "target/llama-libs/libggml-base.so.0",
          "/usr/lib/visual-contextualizer/libggml-cpu.so.0": "target/llama-libs/libggml-cpu.so.0"
        }
      },
      "rpm": {
        "files": {
          "/usr/lib/visual-contextualizer/libllama.so.0": "target/llama-libs/libllama.so.0",
          "/usr/lib/visual-contextualizer/libmtmd.so.0": "target/llama-libs/libmtmd.so.0",
          "/usr/lib/visual-contextualizer/libggml.so.0": "target/llama-libs/libggml.so.0",
          "/usr/lib/visual-contextualizer/libggml-base.so.0": "target/llama-libs/libggml-base.so.0",
          "/usr/lib/visual-contextualizer/libggml-cpu.so.0": "target/llama-libs/libggml-cpu.so.0"
        }
      },
      "appimage": {
        "files": {
          "/usr/lib/visual-contextualizer/libllama.so.0": "target/llama-libs/libllama.so.0",
          "/usr/lib/visual-contextualizer/libmtmd.so.0": "target/llama-libs/libmtmd.so.0",
          "/usr/lib/visual-contextualizer/libggml.so.0": "target/llama-libs/libggml.so.0",
          "/usr/lib/visual-contextualizer/libggml-base.so.0": "target/llama-libs/libggml-base.so.0",
          "/usr/lib/visual-contextualizer/libggml-cpu.so.0": "target/llama-libs/libggml-cpu.so.0"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}