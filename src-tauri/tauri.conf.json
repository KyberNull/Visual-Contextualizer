{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "visual-contextualizer",
  "version": "0.1.0",
  "identifier": "io.github.KyberNull.visual-contextualizer",
  "build": {
    "afterBuildCommand": "SKIP_TAURI_BUILD=1 bash ../scripts/package-portable.sh",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Visual Contextualizer",
        "width": 400,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}